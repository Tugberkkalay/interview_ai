# ========================================
# AI Interview Platform - Hetzner Server
# Environment Configuration Template
# ========================================

# Copy this file to .env and fill in your values:
# cp env.template.hetzner .env

# ========================================
# Django Core Settings
# ========================================

# IMPORTANT: Set to False in production!
DEBUG=False

# Generate a strong secret key (run: python3 -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=your-super-secret-key-here-please-change-this

# Your domain and server IP (comma-separated, no spaces)
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,your-server-ip,localhost

# ========================================
# Database Configuration
# ========================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://interview_user:your_db_password_here@localhost:5432/interview_db

# ========================================
# API Keys
# ========================================

# Google Gemini API Key (get it from: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# ========================================
# CORS & Frontend Settings
# ========================================

# Frontend URLs for CORS (comma-separated, no spaces)
# Example: https://interview.example.com,https://www.interview.example.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Frontend URL for email links and redirects
FRONTEND_URL=https://your-frontend-domain.com

# ========================================
# Security Settings (Production)
# ========================================

# IMPORTANT: Keep these as True in production with HTTPS
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# Production flag (needed for WhiteNoise and security settings)
RENDER=true

# ========================================
# Initial Setup (Optional)
# ========================================

# Auto-create admin user on first deployment (then disable)
CREATE_ADMIN_USER=true
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change_this_password_now

# ========================================
# Email Configuration (Optional)
# ========================================

# Uncomment and configure if using email features

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password

# ========================================
# Error Tracking (Optional)
# ========================================

# Sentry DSN for error tracking (get it from: https://sentry.io)
# SENTRY_DSN=your-sentry-dsn-here

# ========================================
# ATS Integration (Optional)
# ========================================

# If using external ATS systems, add their API keys here
# ATS_API_KEY=your-ats-api-key
# ATS_WEBHOOK_SECRET=your-webhook-secret

# ========================================
# File Upload Limits (Optional)
# ========================================

# Maximum file upload size in bytes (default: 10MB)
# DATA_UPLOAD_MAX_MEMORY_SIZE=10485760

# ========================================
# Notes:
# ========================================
# 
# 1. NEVER commit this file to git (it should be in .gitignore)
# 2. Keep SECRET_KEY strong and unique
# 3. Use strong database passwords
# 4. Set DEBUG=False in production
# 5. Make sure all URLs use HTTPS in production
# 6. Restrict file permissions: chmod 600 .env
# 
# For more help: https://docs.djangoproject.com/en/4.2/howto/deployment/
