# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# PostgreSQL Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local development (no password):
DATABASE_URL=postgresql://localhost:5432/interview_db
# With password:
# DATABASE_URL=postgresql://username:password@localhost:5432/interview_db
# Remote (example):
# DATABASE_URL=postgresql://user:pass@db.example.com:5432/interview_db

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
